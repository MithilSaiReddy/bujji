# Virtual environment
.venv/
venv/
env/
# specific to conda
.conda/ 

# Editor/IDE files
.idea/  # specific to PyCharm
.vscode/ # specific to VS Code (optional, can contain useful config)
*.swp   # specific to Vim

# OS and misc files
.DS_Store # specific to macOS
Thumbs.db # specific to Windows

# Data and logs
*.log
/data/ # if your project generates large data files

# Python version file
.python-version


# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
/dist/
/build/
*.egg-info/
*.wheel

# Virtual environments (uv manages these in .venv)
.venv/

.pyproject.toml
# uv-specific
# It is generally recommended to COMMIT uv.lock for applications, 
# but you can ignore it for libraries if you prefer.
# uv.lock

# Ruff cache (if using ruff with uv)
.ruff_cache/

